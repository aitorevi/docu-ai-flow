{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information"
    }
  },
  "Folders": {
    "Inbox": "../../data/inbox",
    "Archive": "../../data/archive",
    "Failed": "../../data/failed",
    "Output": "../../data/output",
    "MaxConcurrency": 1,
    "PollSeconds": 3
  },
  "Database": {
    "Path": "../../data/invoices.db"
  }
}
