# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Key format: Section__Key  (double underscore = config section separator in .NET)

# Google Document AI — active invoice extractor.
# Credentials come from the service-account JSON pointed to by GOOGLE_APPLICATION_CREDENTIALS (ADC).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GoogleDocumentAi__ProjectId=your-gcp-project-id
GoogleDocumentAi__Location=eu
GoogleDocumentAi__ProcessorId=your-processor-id
# Your own company identity — filtered out of the extracted supplier fields.
Company__TaxId=
Company__Name=

# LlamaParse — reference adapter only. Needed solely if you bind it in Program.cs.
LlamaParse__ApiKey=llx-your-key-here

Resend__ApiKey=re_your-key-here
Resend__FromAddress=facturas@tudominio.com
Resend__AdvisorAddress=asesor@gestoria.com
# Opcional: copia del correo al remitente
Resend__CcAddress=
